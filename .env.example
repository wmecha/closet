NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Set to true only for an explicit local, unauthenticated planning preview.
NEXT_PUBLIC_DEMO_MODE=false

# ---------------------------------------------------------------------------
# SHAWN Apparel storefront
# ---------------------------------------------------------------------------

# Service role key. Server side only, never exposed to the browser. Used for the
# controlled inventory and payment operations (reserve, confirm, release).
SUPABASE_SERVICE_ROLE_KEY=

# Paystack. Get these from your Paystack dashboard. The secret key is server
# side only. Amounts are charged in Kenyan Shillings (KES).
PAYSTACK_SECRET_KEY=
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=
